msgstr "das tonturas"

#: src/buildings.c:1057
msgid "incapacitation"
msgstr "do esgotamento"

#: src/buildings.c:1063
msgid "awkwardness"
msgstr "do desajeitamento"

#: src/buildings.c:1069
msgid "mental deficiency"
msgstr "da deficiência mental"

#: src/buildings.c:1075
msgid "weakness"
msgstr "da fraqueza"

#: src/buildings.c:1081
msgid "ignorance"
msgstr "da ignorância"

#: src/buildings.c:1091
msgid "`KEY`a`end`) buy something"
msgstr "`KEY`a`end`) comprar alguma coisa"

#: src/buildings.c:1092
msgid "`KEY`b`end`) ask for curse removal"
msgstr "`KEY`b`end`) pedir a quebra de uma maldição"

#: src/buildings.c:1093
msgid "`KEY`c`end`) receive healing"
msgstr "`KEY`c`end`) receber cura"

#: src/buildings.c:1097
#, c-format
msgid "`KEY`%c`end`) heal from %s"
msgstr "`KEY`%c`end`) curar-te %s"

#: src/buildings.c:1119
msgid "There is no sign of curse upon your possessions."
msgstr "Não há sinal de maldição nos teus pertences."

#: src/buildings.c:1124 src/scrolls.c:848
msgid "Choose an item to uncurse"
msgstr "Escolhe um objeto para libertar da maldição"

#: src/buildings.c:1130
msgid "Very well - your belongings shall remain as they were."
msgstr "Muito bem - os teus bens ficarão como estavam."

#: src/buildings.c:1148
#, c-format
msgid ""
