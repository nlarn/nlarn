"m:el,el,el,del|los,los,los,de los\n"
"ma:el,al,el,del|los,a los,los,de los\n"
"md:el,el,el,de|los,los,los,de\n"
"f:la,la,la,de la|las,las,las,de las\n"
"fa:la,a la,la,de la|las,a las,las,de las\n"
"fd:la,la,la,de|las,las,las,de\n"
"fe:el,el,el,del|las,las,las,de las"

#. TRANSLATORS: The second person singular possessive pronoun.
#. May be translated to a table of noun classes with declined
#. forms; see grammar.c for the format. German example:
#. "m:dein,deinen,deinem,deines\nf:deine,deine,deiner,deiner\n..."
#: src/grammar.c:89
msgctxt "grammar"
