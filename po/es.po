msgid "Zaaaappp! You've been teleported!"
msgstr "¡Zaaaas! ¡La magia te teletransporta!"

#: src/sobjects.c:1028
msgid "You destroy the altar."
msgstr "Destruyes el altar."

#: src/sobjects.c:1032
msgid "Lightning comes crashing down from above!"
msgstr "¡Un relámpago cae desde lo alto!"

#: src/sobjects.c:1047
msgid "You destroy the fountain."
msgstr "Destruyes la fuente."

#: src/sobjects.c:1052
msgid "A flood of water gushes forth!"
msgstr "¡Brota un torrente de agua!"

