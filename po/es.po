msgid "The door shatters!"
msgstr "¡La puerta se hace astillas!"

#: src/sobjects.c:1093
msgid "Somehow that did not work."
msgstr "Por alguna razón, no ha funcionado."

#: src/sobjects.c:1099
#, c-format
msgid "You destroy %s."
msgstr "Destruyes %s."

