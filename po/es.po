msgid "I see no stairway up here."
msgstr "No veo escaleras de subida aquí."

#: src/sobjects.c:892
#, c-format
msgid "You climb up %s."
msgstr "Subes por %s."

#: src/sobjects.c:919 src/sobjects.c:979
msgid "There is no throne here."
msgstr "Aquí no hay ningún trono."

#: src/sobjects.c:923
msgid "You try to remove the gems from the throne."
msgstr "Intentas arrancar las gemas del trono."

#: src/sobjects.c:927
msgid "There are no gems left on this throne."
msgstr "No quedan gemas en este trono."

