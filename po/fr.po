msgstr "les vertiges"

#: src/buildings.c:1057
msgid "incapacitation"
msgstr "l'épuisement"

#: src/buildings.c:1063
msgid "awkwardness"
msgstr "la gaucherie"

#: src/buildings.c:1069
msgid "mental deficiency"
msgstr "la déficience mentale"

#: src/buildings.c:1075
msgid "weakness"
msgstr "la faiblesse"

#: src/buildings.c:1081
msgid "ignorance"
msgstr "l'ignorance"

#: src/buildings.c:1091
msgid "`KEY`a`end`) buy something"
msgstr "`KEY`a`end`) acheter quelque chose"

#: src/buildings.c:1092
